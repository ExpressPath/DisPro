{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "excludeFiles": "{release,release-verify,dist,android/process-app/app/build}/**"
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "/api/index.ts"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/account/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/wallet(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/payouts(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/downloads(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/updates(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/billing/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/use/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/nodes(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/orders(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/process/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
